{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/manifest" },
    { "path": "./packages/lockfile" },
    { "path": "./packages/registry" },
    { "path": "./packages/cli" }
  ],
  "include": [],
  "exclude": ["node_modules", "dist", "**/dist"]
}
