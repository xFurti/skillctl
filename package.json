{
  "name": "skillctl",
  "version": "0.3.1",
  "private": true,
  "description": "Universal package-manager-like CLI for Agent Skills",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/skillctl.git"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:cli": "pnpm --filter @skillctl/cli build",
    "dev": "pnpm --filter @skillctl/cli dev",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "prepublishOnly": "pnpm build",
    "publish:dry": "pnpm --filter @skillctl/cli pack --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
