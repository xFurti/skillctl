{
  "name": "leogriel",
  "version": "1.0.0-beta.2",
  "private": true,
  "description": "Leogriel — weave Agent Skills into every workflow",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/leogriel.git"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:cli": "pnpm --filter @leogriel/cli build",
    "dev": "pnpm --filter @leogriel/cli dev",
    "clean": "pnpm -r run clean",
    "lint": "pnpm -r lint",
    "test": "pnpm run test:scripts && pnpm -r --workspace-concurrency=1 test",
    "test:scripts": "node --test scripts/test/*.test.mjs",
    "test:coverage": "c8 --all --include=\"packages/*/dist/**/*.js\" --exclude=\"packages/*/dist/test/**\" --check-coverage --lines 60 --functions 60 --statements 60 --branches 50 --reporter=text --reporter=lcov pnpm -r --workspace-concurrency=1 test",
    "version:set": "node scripts/set-version.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:pack": "node scripts/pack-all.mjs",
    "prepublishOnly": "pnpm build",
    "publish:dry": "pnpm --filter @leogriel/cli pack --dry-run"
  },
  "devDependencies": {
    "c8": "11.0.0",
    "typescript": "^5.6.3"
  }
}
