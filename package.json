{
  "name": "skillctl",
  "version": "0.5.0",
  "private": true,
  "description": "Universal package-manager-like CLI for Agent Skills",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/skillctl.git"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "pnpm -r build",
    "build:cli": "pnpm --filter @skillctl/cli build",
    "dev": "pnpm --filter @skillctl/cli dev",
    "clean": "pnpm -r clean",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:coverage": "c8 --all --include=\"packages/*/dist/**/*.js\" --exclude=\"packages/*/dist/test/**\" --check-coverage --lines 60 --functions 60 --statements 60 --branches 50 --reporter=text --reporter=lcov corepack pnpm -r test",
    "version:set": "node scripts/set-version.mjs",
    "release:check": "node scripts/release-check.mjs",
    "release:pack": "node scripts/pack-all.mjs",
    "prepublishOnly": "pnpm build",
    "publish:dry": "pnpm --filter @skillctl/cli pack --dry-run"
  },
  "devDependencies": {
    "c8": "11.0.0",
    "typescript": "^5.6.3"
  }
}
