{
  "name": "@skillctl/registry",
  "version": "0.2.0",
  "description": "Registry manager, sources (github, local, skills.sh, basic npm) + resolution + materialize + integrity for skillctl",
  "license": "MIT",
  "author": "skillctl contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js 2>&1 || echo 'run after build; basic resolution tests'",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@skillctl/core": "workspace:*",
    "@skillctl/lockfile": "workspace:*",
    "@skillctl/manifest": "workspace:*",
    "semver": "^7.6.3",
    "tar": "^6.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/semver": "^7.5.8",
    "@types/tar": "^6.1.13",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skillctl/skillctl.git",
    "directory": "packages/registry"
  },
  "keywords": [
    "registry",
    "sources",
    "github",
    "npm",
    "resolution",
    "agent-skills"
  ]
}
