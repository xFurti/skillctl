{
  "name": "@leogriel/link-manager",
  "version": "1.0.0-beta.2",
  "description": "Cross-platform symlink, junction, and managed-copy support for Leogriel",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/test"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@leogriel/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/leogriel.git",
    "directory": "packages/link-manager"
  },
  "keywords": [
    "link-manager",
    "symlink",
    "junction",
    "skills",
    "agent-skills"
  ]
}
