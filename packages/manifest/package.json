{
  "name": "@skillctl/manifest",
  "version": "0.2.0",
  "description": "agent-skills.json parser, generator, and Zod schema for skillctl",
  "license": "MIT",
  "author": "skillctl contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js 2>&1 || echo 'no dist tests or node test runner skipped; run after build'",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@skillctl/core": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/skillctl.git",
    "directory": "packages/manifest"
  },
  "keywords": [
    "manifest",
    "agent-skills.json",
    "schema",
    "zod"
  ]
}
