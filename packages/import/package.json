{
  "name": "@leogriel/import",
  "version": "1.0.0-beta.2",
  "description": "Import and migrate Agent Skills from projects, npx skills, and legacy Python skillctl",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/test"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@leogriel/core": "workspace:*",
    "@leogriel/lockfile": "workspace:*",
    "@leogriel/manifest": "workspace:*",
    "@leogriel/registry": "workspace:*",
    "@leogriel/adapters": "workspace:*",
    "@leogriel/project-state": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/leogriel.git",
    "directory": "packages/import"
  },
  "keywords": [
    "import",
    "migration",
    "npx-skills",
    "agent-skills"
  ]
}
