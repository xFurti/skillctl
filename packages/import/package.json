{
  "name": "@skillctl/import",
  "version": "0.2.0",
  "description": "Import and migrate skills from npx skills and Python skillctl",
  "license": "MIT",
  "author": "skillctl contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js 2>&1 || echo 'run after build'",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@skillctl/core": "workspace:*",
    "@skillctl/lockfile": "workspace:*",
    "@skillctl/manifest": "workspace:*",
    "@skillctl/registry": "workspace:*",
    "@skillctl/adapters": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": { "node": ">=22.13" },
  "repository": {
    "type": "git",
    "url": "https://github.com/skillctl/skillctl.git",
    "directory": "packages/import"
  },
  "keywords": ["import", "migration", "npx-skills", "agent-skills"]
}