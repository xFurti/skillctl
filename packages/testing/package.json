{
  "name": "@leogriel/testing",
  "version": "1.0.0-beta.1",
  "description": "Experimental behavioral testing primitives for Leogriel; API unstable until 1.0",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/test",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js",
    "test:live": "pnpm run build && node --test ./dist/live/*.test.js",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@leogriel/core": "workspace:*",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/leogriel.git",
    "directory": "packages/testing"
  },
  "keywords": [
    "agent-skills",
    "behavioral-testing",
    "experimental"
  ]
}
