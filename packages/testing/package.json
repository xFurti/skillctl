{
  "name": "@skillctl/testing",
  "version": "0.8.0",
  "description": "Experimental behavioral testing primitives for skillctl; API unstable until 1.0",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "!dist/test", "README.md"],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js",
    "test:live": "pnpm run build && node --test ./dist/live/*.test.js",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@skillctl/core": "workspace:*",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": { "node": ">=22.13" },
  "publishConfig": { "access": "public", "provenance": true },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/skillctl.git",
    "directory": "packages/testing"
  },
  "keywords": ["agent-skills", "behavioral-testing", "experimental"]
}
