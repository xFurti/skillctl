{
  "name": "@leogriel/project-state",
  "version": "1.0.0-beta.2",
  "description": "Transactional project state and cross-process operation locks for Leogriel",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/test",
    "!dist/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@leogriel/core": "workspace:*",
    "@leogriel/manifest": "workspace:*",
    "@leogriel/lockfile": "workspace:*",
    "proper-lockfile": "4.1.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/proper-lockfile": "^4.1.4",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/leogriel.git",
    "directory": "packages/project-state"
  }
}
