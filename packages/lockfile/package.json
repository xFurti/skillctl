{
  "name": "@skillctl/lockfile",
  "version": "0.2.0",
  "description": "agent-skills.lock YAML parser/generator with lockfileVersion and provenance for skillctl",
  "license": "MIT",
  "author": "skillctl contributors",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js 2>&1 || echo \"lockfile tests placeholder (fixtures+validation present; run build+manual)\" && exit 0",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@skillctl/core": "workspace:*",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/skillctl.git",
    "directory": "packages/lockfile"
  },
  "keywords": [
    "lockfile",
    "agent-skills.lock",
    "yaml",
    "pnpm-style"
  ]
}
