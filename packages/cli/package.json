{
  "name": "@leogriel/cli",
  "version": "1.0.0-beta.2",
  "description": "Leogriel CLI — weave Agent Skills into every workflow",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "contributors": [
    "xFurti <https://github.com/xFurti>",
    "Gabry848 <https://github.com/gabry848>"
  ],
  "bugs": "https://github.com/xFurti/leogriel/issues",
  "homepage": "https://xfurti.github.io/leogriel/",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "leogriel": "./bin/leogriel.js"
  },
  "files": [
    "bin",
    "dist",
    "!dist/test",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js",
    "prepack": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@leogriel/core": "workspace:*",
    "@leogriel/manifest": "workspace:*",
    "@leogriel/lockfile": "workspace:*",
    "@leogriel/registry": "workspace:*",
    "@leogriel/link-manager": "workspace:*",
    "@leogriel/adapters": "workspace:*",
    "@leogriel/import": "workspace:*",
    "@leogriel/security": "workspace:*",
    "@leogriel/plugin-system": "workspace:*",
    "@leogriel/project-state": "workspace:*",
    "@leogriel/testing": "workspace:*",
    "@clack/prompts": "^0.11.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/leogriel.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "cli",
    "skills",
    "agent-skills",
    "ai",
    "agents"
  ]
}
