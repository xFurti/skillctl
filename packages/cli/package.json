{
  "name": "@skillctl/cli",
  "version": "0.7.3",
  "description": "skillctl CLI - universal manager for Agent Skills",
  "license": "MIT",
  "author": "xFurti & Gabry848",
  "contributors": [
    "xFurti <https://github.com/xFurti>",
    "Gabry848 <https://github.com/gabry848>"
  ],
  "bugs": "https://github.com/xFurti/skillctl/issues",
  "homepage": "https://xfurti.github.io/skillctl/",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "skillctl": "./bin/skillctl.js"
  },
  "files": [
    "bin",
    "dist",
    "!dist/test",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "node --test ./dist/test/*.test.js",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@skillctl/core": "workspace:*",
    "@skillctl/manifest": "workspace:*",
    "@skillctl/lockfile": "workspace:*",
    "@skillctl/registry": "workspace:*",
    "@skillctl/link-manager": "workspace:*",
    "@skillctl/adapters": "workspace:*",
    "@skillctl/import": "workspace:*",
    "@skillctl/security": "workspace:*",
    "@skillctl/plugin-system": "workspace:*",
    "@skillctl/project-state": "workspace:*",
    "@clack/prompts": "^0.11.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "rimraf": "^5.0.7",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xFurti/skillctl.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "cli",
    "skills",
    "agent-skills",
    "ai",
    "agents"
  ]
}
